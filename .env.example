# The URL of the Java-based Lucene NLP microservice.
# When running via Docker Compose, this should point to the internal Docker network alias.
LUCENE_URL=http://lucene:4567

# The address of the Kafka broker for asynchronous log streaming.
# In Docker Compose, this points to the 'kafka' service on the default port.
KAFKA_BROKER=kafka:9092

# The hostname of the Redis session store used for tracking user conversation state.
# When running locally without Docker, you can set this to 'localhost'.
REDIS_HOST=redis

# Toggles the multilingual translation pipeline on or off. 
# Set to 1 to enable, 0 to disable.
ENABLE_TRANSLATION=1

# The minimum confidence threshold (0.0 to 1.0) required for the ML model 
# to accept a predicted intent. If the score falls below this, it triggers a fallback.
INTENT_MIN_CONFIDENCE=0.35

# The minimum relevance score required for a Lucene fuzzy search hit to be 
# considered a valid answer for the user's query.
LUCENE_MIN_SCORE=2.0
